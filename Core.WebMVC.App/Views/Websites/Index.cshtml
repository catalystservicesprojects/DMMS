@model IEnumerable<DMMS.WebMVC.App.Models.Website>

@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h1>Index</h1>

<p>
    <a href="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Name)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Alias)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Url)
            </th>
            @*             <th>
                @Html.DisplayNameFor(model => model.Guid)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Identity)
            </th> *@
            <th>
                @Html.DisplayNameFor(model => model.Status)
            </th>
            @*             <th>
                @Html.DisplayNameFor(model => model.Tenant)
            </th> *@
            @*             <th>
                @Html.DisplayNameFor(model => model.CreatedBy)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.CreationDate)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.ModifiedBy)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.ModifiedDate)
            </th> *@
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>
                    <img src="@Html.DisplayFor(modelItem => item.LogoLink)" style="width:100px; height:30px; cursor:pointer; text-align: left" onclick="showImageModal('@Html.DisplayFor(modelItem => item.LogoLink)')" />
                </td>
                <td>
                    <a href="@Url.Action("Index", "Contents",
                                                                                          new { ContentId = item.Id, Mode = "Edit", companyIdentity = ViewBag.Company, websiteIdentity = item.Identity })"
                       style="text-decoration:none; color: darkblue"
                       class="play-btn">@Html.DisplayFor(modelItem => item.Name)</a>
                </td>
                <td>
                    <a href="@Url.Action("Index", "Contents",
                                                                                  new { ContentId = item.Id, Mode = "Edit", companyIdentity = ViewBag.Company, websiteIdentity = item.Identity })"
                       style="text-decoration:none; color: darkblue"
                       class="linkText">@Html.DisplayFor(modelItem => item.Alias)</a>
                </td>
                <td>
                    <a href="@item.Url" target="_blank">@item.Url</a>
                </td>
                @*             <td>
                @Html.DisplayFor(modelItem => item.Guid)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Identity)
            </td> *@
                <td>
                    <a href="Edit" class="btn btn-success">Active</a>
                </td>
                @*             <td>
                @Html.DisplayFor(modelItem => item.Tenant)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.CreatedBy)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.CreationDate)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.ModifiedBy)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.ModifiedDate)
            </td> *@
                <td>
                    <div class="btn-group">
                        <a href="Edit" class="btn btn-info">Edit</a>
                        <a href="Details" class="btn btn-warning">Details</a>
                        <a href="Delete" class="btn btn-danger">Delete</a>
                    </div>
                    @* <a href="Edit" asp-route-id="@item.Id">Edit</a> |
                    <a href="Details" asp-route-id="@item.Id">Details</a> |
                    <a href="Delete" asp-route-id="@item.Id">Delete</a> *@
                </td>
            </tr>
        }
    </tbody>
</table>
<div class="modal fade" id="imageModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-body text-center">
                <img id="modalImage" src="" style="width:100%;" />
            </div>
        </div>
    </div>
</div>
<script>
    function showImageModal(imageUrl) {
        document.getElementById("modalImage").src = imageUrl;

        var modal = new bootstrap.Modal(document.getElementById('imageModal'));
        modal.show();
    }
</script>