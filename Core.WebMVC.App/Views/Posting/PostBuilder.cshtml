                            }
                            else
                            {
                                <div class="row mb-1">
                                    <div class="col-sm-2">
                                        <input type="text" id="af_seller_name_@Model.SellerEntities[i].Id" style="padding-left: 40px" value="" class="affiliate seller-name col-sm-2 col-form-label" />
                                    </div>
                                    <div class="col-sm-3">
                                        <input type="text" class="affiliate price form-control" id="af_price_@Model.SellerEntities[i].Id" placeholder="Price">
                                    </div>
                                    <div class="col-sm-7">
                                        <input type="text" class="affiliate form-control" id="af_link_@Model.SellerEntities[i].Id" placeholder="Affiliate Link">
                                    </div>
                                </div>
                            }
                        </div> *@
                    </td>
                </tr>
            }
        </table>
        <p for="external_links"><h3>Sliders Links & Social Links:</h3></p>
        <table id="external_links" class="externalTable" style="width: 100%">
            @for (int i = 0; i < Model.Images.Count; i++)
            {
                <tr>
                    <td>
                        <div class="col">
                            @if (i == 0)
                            {
                                <div class="mr-3 mb-1">
                                    <input type="text" class="eximage form-control" id="image_@(i + 1)" value="@ViewBag.ImageLink" placeholder="@Model.Images[i] @(i + 1) Link">
                                </div>
                            }
                            else
                            {
                                <div class="mr-3 mb-1">
                                    <input type="text" class="eximage form-control" id="image_@(i + 1)" placeholder="@Model.Images[i] @(i + 1) Link">
                                </div>
                            }
                        </div>
                    </td>
                    <td>
                        <div class="col">
                            <div class="mr-3 mb-1">
                                <input type="text" class="exvideo form-control" id="video_@(i + 1)" placeholder="@Model.Videos[i] @(i + 1) Link">
                            </div>
                        </div>
                    </td>
                    <td>
                        <div class="col">
                            <div class="mr-3 mb-1">
                                <input type="text" class="exsocial form-control" id="social_@(i + 1)" placeholder="@Model.Socials[i] Post Link">
                            </div>
                        </div>
                    </td>
                </tr>
            }
        </table>
    </div>
    <div class="col">
        <p for="external_links"><h3>Reference Links:</h3></p>
        <table id="external_links" class="externalTable" style="width: 100%">
