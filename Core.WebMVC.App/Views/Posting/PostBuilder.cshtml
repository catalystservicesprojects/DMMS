                                </div>
                            </div>
                        </td>
                        <td>
                            <div class="col">
                                <div class="mr-3 mb-1">
                                    <input type="text" class="article form-control" id="article_link_@(i + 1)" placeholder="Article @(i + 1) Link">
                                </div>
                            </div>
                        </td>
                        <td>
                            <div class="col">
                                <div class="mr-3 mb-1">
                                    <input type="text" class="article form-control" id="article_image_@(i + 1)" placeholder="Article @(i + 1) Image Link">
