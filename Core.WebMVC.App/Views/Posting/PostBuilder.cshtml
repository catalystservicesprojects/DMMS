                            {
                                <div class="row mb-1">
                                    <label id="af_seller_name_@Model.SellerEntities[i + 1].Id" value="" style="padding-left: 50px" class="col-sm-2 col-form-label">@Model.SellerEntities[i + 1].Name</label>
                                    <div class="col-sm-3">
                                        <input type="text" class="affiliate price form-control" id="af_price_@Model.SellerEntities[i + 1].Id" placeholder="Price">
                                    </div>
                                    <div class="col-sm-7">
                                        <input type="text" class="affiliate form-control" id="af_link_@Model.SellerEntities[i + 1].Id" placeholder="Affiliate Link">
