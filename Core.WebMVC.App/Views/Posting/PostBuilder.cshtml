    function collectExternalSingleLinkData(currentElement) {
    const contentId = $('#ContentId').val();
    let idString = currentElement[0].id;                    // extract 23
    let id = idString.split('_')[1];                        // extract 23
    let Wordorsentense = $("#wordOrSentence_" + id).val();
    let link = $("#backLink_" + id).val();                  // matching link input
    let externalLinksData = {
    Id: 0,
    Link: htmlEntityCodec.decode(link),
    WordOrSentense: htmlEntityCodec.decode(Wordorsentense),
    ContentId: contentId,
    CompanyId: 9,
    UserId: 1,
    Guid: self.crypto.randomUUID(),          // generates a unique GUID in JS
    Identity: "System",                      // or current user
    Status: 1,                               // set your default status
    Tenant: 1,                               // replace with actual tenant
    CreatedBy: 1,                            // or current logged-in user
    CreationDate: new Date().toISOString(),  // current timestamp
    ModifiedBy: 1,                           // or current user
    ModifiedDate: new Date().toISOString()   // current timestamp
    };
    return externalLinksData;
    }

    $('.external_links').on('focusout', function () {
    let currentElement = $(this);

    let idString = currentElement[0].id;                    // extract 23
    let id = idString.split('_')[1];                        // extract 23
    let Wordorsentense = $("#wordOrSentence_" + id);
    let link = $("#backLink_" + id);                        // matching link input
    let dataToSend = collectExternalSingleLinkData(currentElement);

    $.ajax({
    url: "/Posting/SaveExternalSingleLinkData",
    type: "POST",
    data: dataToSend,
    success: function (response) {
    // ON 200 OK
    if (response.status === "inserted") {
    console.log("Inserted:", response.id);
    currentElement.css("border", "3px solid green");
    link.css("border", "3px solid green");
    Wordorsentense.css("border", "3px solid green");
    }
    else if (response.status === "updated") {
    console.log("Updated:", response.id);
    currentElement.css("border", "3px solid #00ffff");
    link.css("border", "3px solid #00ffff");
    Wordorsentense.css("border", "3px solid #00ffff");
    }
    else if (response.status === "skipped") {
    console.log("Skipped:", response.id);
    currentElement.css("border", "3px solid blue");
    link.css("border", "3px solid blue");
    Wordorsentense.css("border", "3px solid blue");
    }
    },
    error: function () {
    alert("Error loading publishers.");
    // ON ERROR
    currentElement.css("border", "2px solid red");
    },
    complete: function () {
    // AFTER SUCCESS OR ERROR
    console.log("Request completed");
    updateExternalLinks(Wordorsentense, link);
    //alert("Target: " + Wordorsentense + ", Value: " + link);
    },

    // PROMISE CALLBACKS
    done: function (res) {
    console.log("Done (success only):", res);
    },
    fail: function (xhr) {
    console.log("Fail (error only):", xhr.status);
    },
    always: function () {
    console.log("Always executed (success or error)");
    }
    });
    });

    function updateExternalLinks(target, value) {
    let targetText = target.val().trim();
    let valueText = value.val().trim();
    if(targetText != '' && valueText != ''){
    let viewHtml = $("#view_content").html();
    // Create the link
    let link = "<a href='" + valueText + "' style='text-decoration: none; color: blue' target='_blank'>" + targetText + "</a>";
    // Replace occurrences of the target
    viewHtml = viewHtml.replace(new RegExp(targetText, "g"), link);
    $("#view_content").html(viewHtml);
    }
    }

    function BulkuUdateExternalLinks() {
    $("input[id^='wordOrSentence']").each(function () {
    let id = this.id.replace("wordOrSentence", "");
    let Wordorsentense = $(this);
    let link = $("#backLink" + id);
    updateExternalLinks(Wordorsentense, link);
    });
    }

