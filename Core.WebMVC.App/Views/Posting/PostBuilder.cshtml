                                                                                                                                                                && Model.PreviousContentArticleLinksReferences[i].Title != null)
                    {
                        <td>
                            <div class="col">
                                <div class="mr-3 mb-1">
                                    <input type="text" class="article form-control" id="article_title_@(i + 1)"
