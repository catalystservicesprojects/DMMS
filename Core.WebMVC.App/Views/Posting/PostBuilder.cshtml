                            </div>
                        </td>
                        <td>
                            <div class="col">
                                <div class="mr-3 mb-1">
                                    <input type="text" class="post form-control" id="post_image_@(i + 1)"
                                           value="@Model.PreviousContentProductLinksReferences[i].ImageLink" placeholder="Product @(i + 1) Image Link">
                                </div>
                            </div>
                        </td>
                    }
