<input type="hidden" value="@ViewBag.SecondaryKeyword" name="SecondaryKeyword" id="SecondaryKeyword" class="form-control" placeholder="Secondary Keyword" />
<input type="hidden" value="@HttpContextAccessor.HttpContext.Session.GetInt32("CompanyId")" name="CompanyId" id="CompanyId" class="form-control" placeholder="Company Id" />
<input type="hidden" value="@HttpContextAccessor.HttpContext.Session.GetInt32("UserId")" name="UserId" id="UserId" placeholder="User Id" />
@{
    var newGuid = Guid.NewGuid();
    var newGuidTrimmed = newGuid.ToString().Replace("-", "").ToLower();
}
<input type="hidden" value="@newGuid" name="Guid" id="Guid" placeholder="Guid" />
<input type="hidden" value="@newGuidTrimmed" name="Identity" id="Identity" class="form-control" placeholder="Identity" />
<input type="hidden" value="1" name="Status" id="Status" placeholder="Status" />
<input type="hidden" value="0" name="Tenant" id="Tenant" placeholder="Tenant" />
<input type="hidden" value="1" name="CreatedBy" id="CreatedBy" placeholder="CreatedBy" />
<input type="hidden" value="@DateTime.Now" name="CreationDate" id="CreationDate" placeholder="CreationDate" />
<input type="hidden" value="1" name="ModifiedBy" id="ModifiedBy" placeholder="ModifiedBy" />
<input type="hidden" value="@DateTime.Now" name="ModifiedDate" id="ModifiedDate" placeholder="ModifiedDate" />
<input type="hidden" value="@Model.ProductHtml" name="ProductHtml" id="ProductHtml" placeholder="ProductHtml" />
<input type="hidden" name="Product Buy Buttons" id="ProductBuyButtons" placeholder="Product Buy Buttons" />

