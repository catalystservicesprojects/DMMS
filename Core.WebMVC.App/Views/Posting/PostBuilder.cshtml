<!---------------------------------------------------------------------Bottom Buttons Starts------------------------------------------------------------------------>
<div id="ButtonRowTop" class="row" style="display: flex;">
    <div class="col" style="display: flex; justify-content: left;">
        <button id="TopStagePrev" type="button" class="btn btn-primary" style="width: 150px; margin: 10px">Previous</button>
    </div>
    <div class="col" style="display: flex; justify-content: center;">
        <div class="pill-nav">
            <a href="#" class="active stage stage1" id="tPill-1">1</a>
            <a href="#" class="stage stage2" id="tPill-2">2</a>
            <a href="#" class="stage stage3" id="tPill-3">3</a>
            <a href="#" class="stage stage4" id="tPill-4">4</a>
            <a href="#" class="stage stage5" id="tPill-5">5</a>
        </div>
    </div>
    <div class="col" style="display: flex; justify-content: right;">
        <button id="TopStageNext" type="button" class="btn btn-primary" style="width: 150px; margin: 10px">Next</button>
    </div>
</div>
<input id="Stage" type="hidden" value="1" />
<!---------------------------------------------------------------------Bottom Buttons Ends-------------------------------------------------------------------------->
<!-----------------------------Stage 1 Starts-------------------------->
<div id="StageOne" class="row">
    <div class="col">
        @{
            string basic_raw = "Title: " + ViewBag.Title + "\n" +
"Link: " + ViewBag.Link + "\n" +
"Image Link: " + ViewBag.ImageLink + "\n" +
"Slug: " + ViewBag.Slug + "\n" +
"Primary Keyword: " + ViewBag.PrimaryKeyword + "\n" +
"Secondary Keywords: " + ViewBag.SecondaryKeywords + "\n" +
"Tertiary Keywords: " + ViewBag.TertiaryKeywords + "\n" +
"Short Title: " + ViewBag.ShortName + "\n" +
"Hook: " + ViewBag.Hook + "\n" +
"Description: " + ViewBag.Description + "\n" +
"Author: " + ViewBag.Author + "\n";
        }
        <p for="raw_content"><h3>Raw Content:</h3></p>
        <textarea id="raw_content" class="form-control" rows="5" name="text" style="width: 100%; min-height: 1500px;">@(Model.ContentRaw != null ? @Model.ContentRaw.Value : basic_raw)</textarea>
    </div>
    <div class="col">
        <p for="ai_content"><h3>AI Content:</h3></p>
        <textarea id="ai_content_introduction" class="form-control" name="text" style="width: 100%; min-height: 200px;" placeholder="Enter Introduction Here">@(Model.ContentAi != null ? @Model.ContentAi.Introduction : "")</textarea>
        <br />
        <textarea id="ai_content" class="form-control" name="text" style="width: 100%; min-height: 1500px;">@(Model.ContentAi != null ? @Model.ContentAi.Value : "")</textarea>
    </div>
</div>
<!-----------------------------Stage 1 Ends---------------------------->
<!-----------------------------Stage 2 Starts-------------------------->
<div id="StageTwo" class="row">
    <div class="col">
        <p for="affiliate_links"><h3>Affiliate Links:</h3></p>
        <table id="affiliate_links" class="linksTable" style="text-align: left">
            @for (int i = 0; i < Model.SellerEntities.Count; i += 2)
            {
                <tr>
                    <td>
                        <div class="col">
                            <div class="row mb-1">
                                <label id="af_seller_name_@Model.SellerEntities[i].Id" value="" style="padding-left: 30px" class="col-sm-2 col-form-label">@Model.SellerEntities[i].Name</label>
                                <div class="col-sm-3">
                                    <input type="number" class="affiliate price form-control" id="af_price_@Model.SellerEntities[i].Id" placeholder="Price">
                                </div>
                                <div class="col-sm-7">
                                    <input type="text" class="affiliate form-control" id="af_link_@Model.SellerEntities[i].Id" placeholder="Affiliate Link">
                                </div>
                            </div>
                        </div>
                    </td>
                    <td>
                        <div class="col">
                            <div class="row mb-1">
                                <label id="af_seller_name_@Model.SellerEntities[i + 1].Id" value="" style="padding-left: 50px" class="col-sm-2 col-form-label">@Model.SellerEntities[i + 1].Name</label>
                                <div class="col-sm-3">
                                    <input type="number" class="affiliate price form-control" id="af_price_@Model.SellerEntities[i + 1].Id" placeholder="Price">
                                </div>
                                <div class="col-sm-7">
                                    <input type="text" class="affiliate form-control" id="af_link_@Model.SellerEntities[i + 1].Id" placeholder="Affiliate Link">
                                </div>
                            </div>
                        </div>
                        @*                         <div class="col">
