            <script>
                            function validateForm() {
                            let isValid = true;
                            let errors = [];

                            function validateRequired(fieldId, fieldName) {
                            const el = document.getElementById(fieldId);
                            if (!el || !el.value.trim()) {
                            isValid = false;
                            errors.push(fieldName + " is required");
                            if (el)
                            el.classList.add("error");
                            } else {
                            el.classList.remove("error");
                            }
                            }

                            function validateUrl(fieldId, fieldName) {
                            const el = document.getElementById(fieldId);
                            if (el && el.value.trim() !== "") {
                            try {
                            new URL(el.value);
                            el.classList.remove("error");
                            } catch {
                            isValid = false;
                            errors.push(fieldName + " must be a valid URL");
                            el.classList.add("error");
                            }
                            }
                            }

                            // Required fields
                            validateRequired("Title", "Title");
                            validateRequired("Link", "Link");
                            validateRequired("ImageLink", "ImageLink");
                            validateRequired("PrimaryKeyword", "PrimaryKeyword");
                            validateRequired("ShortName", "ShortName");
                            validateRequired("Description", "Description");
                            validateRequired("Author", "Author");
                            validateRequired("Robots", "Robots");
                            validateRequired("Hook", "Hook");
                            validateRequired("Language", "Language");
                            validateRequired("Revisit", "Revisit");
                            validateRequired("Slug", "Slug");
                            validateRequired("HookSlug", "HookSlug");

                            // Optional URL validation
                            validateUrl("Link", "Link");
                            validateUrl("ImageLink", "ImageLink");

                            if (!isValid) {
                            alert(errors.join("\n"));
                            }

                            return isValid;
                            }
            </script>
            <script>
                            async function submitFormAjax() {

                            // ✅ Step 1: Validate
                            if (!validateForm()) {
                            return;
                            }

                            const form = document.getElementById("contentMetaForm");
                            const formData = new FormData(form);

                            try {
                            const response = await fetch('/Contents/Update', {
                            method: 'POST',
                            body: formData
                            });

                            if (!response.ok) {
                            throw new Error("Server error");
                            }

                            const result = await response.json();

                            // ✅ Success handling
                            if (result.success) {
                            alert("Saved successfully!");

                            // 🔥 Optional redirect
                            if (result.redirectUrl) {
                            // window.location.href = result.redirectUrl;
                            }
                            } else {
                            alert(result.message || "Something went wrong");
                            }

                            } catch (error) {
                            console.error(error);
                            alert("Error submitting form");
                            }
                            }
            </script>
